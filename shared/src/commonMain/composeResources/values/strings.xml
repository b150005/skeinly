<?xml version="1.0" encoding="utf-8"?>
<!--
  Default (English) string resources for shared Compose Multiplatform UI.
  Consumed via `import io.github.b150005.knitnote.generated.resources.Res`
  and `stringResource(Res.string.<key>)` from commonMain.

  Keys MUST stay in sync with:
    - androidApp/src/main/res/values/strings.xml
    - androidApp/src/main/res/values-ja/strings.xml
    - shared/src/commonMain/composeResources/values-ja/strings.xml
    - iosApp/iosApp/Resources/Localizable.xcstrings
  Run scripts/verify-i18n-keys.sh to detect drift.
-->
<resources>
    <string name="app_name">Knit Note</string>

    <!-- Action primitives (buttons, menu items, a11y labels) -->
    <string name="action_save">Save</string>
    <string name="action_cancel">Cancel</string>
    <string name="action_delete">Delete</string>
    <string name="action_edit">Edit</string>
    <string name="action_ok">OK</string>
    <string name="action_back">Back</string>
    <string name="action_retry">Retry</string>
    <string name="action_close">Close</string>
    <string name="action_discard">Discard</string>
    <string name="action_keep_editing">Keep editing</string>
    <string name="action_undo">Undo</string>
    <string name="action_redo">Redo</string>
    <string name="action_more_options">More options</string>

    <!-- Load / empty states -->
    <string name="state_loading">Loading\u2026</string>
    <string name="state_empty">Nothing here yet</string>
    <string name="state_empty_chart">Empty chart</string>

    <!-- Error messages -->
    <string name="error_generic">Something went wrong</string>
    <string name="error_load">Couldn\'t load</string>
