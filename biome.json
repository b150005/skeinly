{
    "$schema": "https://biomejs.dev/schemas/2.4.14/schema.json",
    "files": {
        "includes": [
            "supabase/functions/**/*.ts",
            "!**/node_modules",
            "!**/build",
            "!**/.gradle",
            "!**/DerivedData",
            "!iosApp/.bundle"
        ]
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 100,
        "lineEnding": "lf"
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true
        }
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "double",
            "trailingCommas": "all",
            "semicolons": "always"
        }
    }
}
