  "strings" : {
    "?" : {
      "comment" : "A question mark glyph.",
      "isCommentAutoGenerated" : true
    },
    "%@" : {
      "comment" : "A label displaying the current row number. The argument is the current row number.",
      "isCommentAutoGenerated" : true
    },
    "%@ · %@ · %@" : {
      "comment" : "A label that shows the number of added, modified, and removed cells in a diff. The format is a localized string with 3 placeholders.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ · %2$@ · %3$@"
          }
        }
      }
    },
    "%@ / %@" : {
      "comment" : "A label showing the count of symbols currently visible in the grid.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
