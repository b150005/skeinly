    "body_bug_report_includes_actions" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Submitting sends this report to the Skeinly team. The report includes your description plus app version, OS, device, locale, and your last 10 actions — no patterns, notes, photos, or PII."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "送信するとレポートが Skeinly チームに送られます。レポートには、入力した内容に加えて、アプリバージョン・OS・デバイス・ロケール・直近 10 件の操作履歴が含まれます。パターン、メモ、写真、個人情報は含まれません。"
          }
        }
      }
    },
    "body_contact_support_helper" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Email the Skeinly team for account questions, refund requests, DMCA notices, or other support."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アカウントに関するお問い合わせ、返金依頼、DMCA 通知などはこちらから Skeinly チームへメールでご連絡ください。"
          }
        }
      }
    },
    "body_delete_account_warning" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deleting your account will permanently remove all your projects, progress, and shared content. This action cannot be undone."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アカウントを削除すると、すべてのプロジェクト、進捗、共有コンテンツが完全に削除されます。この操作は取り消せません。"
          }
        }
      }
    },
    "body_diagnostic_consent" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beta builds can send anonymous diagnostic data to help us track down bugs. Default is off — you choose. You can change this any time in Settings."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ベータビルドでは、不具合の特定に役立てるため匿名の診断データを送信できます。初期設定はオフです。設定からいつでも変更できます。"
          }
        }
      }
    },
    "body_diagnostic_data_explanation" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Anonymous app version, OS, device model, screen names, and tapped action names. Never your patterns, projects, notes, photos, email, or display name. Toggle off any time; turning it off clears the bug-report event trail immediately."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "送信する内容：アプリのバージョン、OS、端末モデル、画面名、タップしたアクション名（いずれも匿名）。送信しない内容：パターン、プロジェクト、メモ、写真、メールアドレス、表示名。いつでもオフに切り替えられます。オフにするとバグレポートに添付される操作履歴も即座に消去されます。"
          }
        }
      }
    },
