    "body_bug_report_includes_actions": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Submitting opens GitHub. The report includes your description plus app version, OS, device, locale, and your last 10 actions — no patterns, notes, photos, or PII."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "送信すると GitHub が開きます。レポートには、入力した内容に加えて、アプリバージョン・OS・デバイス・ロケール・直近 10 件の操作履歴が含まれます。パターン、メモ、写真、個人情報は含まれません。"
          }
        }
      }
    },
    "body_delete_account_warning": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Deleting your account will permanently remove all your projects, progress, and shared content. This action cannot be undone."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アカウントを削除すると、すべてのプロジェクト、進捗、共有コンテンツが完全に削除されます。この操作は取り消せません。"
          }
        }
      }
    },
    "body_diagnostic_consent": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Beta builds can send anonymous diagnostic data to help us track down bugs. Default is off — you choose. You can change this any time in Settings."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ベータビルドでは、不具合の特定に役立てるため匿名の診断データを送信できます。初期設定はオフです。設定からいつでも変更できます。"
          }
        }
      }
    },
    "body_diagnostic_data_explanation": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Anonymous app version, OS, device model, screen names, and tapped action names. Never your patterns, projects, notes, photos, email, or display name. Toggle off any time; turning it off clears the bug-report event trail immediately."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "送信する内容：アプリのバージョン、OS、端末モデル、画面名、タップしたアクション名（いずれも匿名）。送信しない内容：パターン、プロジェクト、メモ、写真、メールアドレス、表示名。いつでもオフに切り替えられます。オフにするとバグレポートに添付される操作履歴も即座に消去されます。"
          }
        }
      }
    },
    "body_no_activity": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your activity will appear here"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アクティビティはここに表示されます"
          }
        }
      }
    },
    "body_onboarding_count": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Never lose your place again. Tap to count rows, add notes, and attach progress photos."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "編みかけの場所を見失いません。タップで段数を数え、メモや進捗写真を残せます。"
          }
        }
      }
    },
    "body_onboarding_library": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Save your favorite patterns with gauge, yarn info, and needle sizes for easy reference."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "お気に入りのパターンをゲージ・糸情報・針号数と一緒に保存できます。"
          }
        }
      }
    },
    "body_onboarding_track": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keep all your knitting projects organized in one place with row counting and progress tracking."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "段数カウントと進捗記録で、すべての編み物プロジェクトを一か所に整理できます。"
          }
        }
      }
    },
    "body_send_feedback_explanation": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Opens a pre-filled GitHub Issue in your browser. The bug report includes the last 10 actions you took (no PII)."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ブラウザで GitHub Issue を開き、内容を事前入力します。直近 10 件の操作履歴（個人情報なし）も添付されます。"
          }
        }
      }
    },
