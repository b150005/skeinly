      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Export a machine-readable copy of the data Skeinly stores for you: your account, patterns, projects, progress, charts, comments, suggestions, and activity. You choose where to save the file."
