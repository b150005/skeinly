        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Skeinly が保存しているデータ（アカウント・パターン・プロジェクト・進捗・編み図・コメント・提案・アクティビティ）を機械可読な形式でエクスポートします。保存先はあなたが選択します。"
          }
