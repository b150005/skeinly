// Local Xcode build settings — copy to local.xcconfig and fill in your values.
// This file is committed to version control as a template.
// local.xcconfig is git-ignored and must NOT be committed.
//
// First-time setup:
//
//   make ios-build
//   # If iosApp/local.xcconfig doesn't exist yet, the Makefile prereq
//   # `.ensure-local-xcconfig` auto-copies this template to
//   # iosApp/local.xcconfig and emits an instructional log.
//   #
//   # Then open iosApp/local.xcconfig and replace YOUR_TEAM_ID_HERE
//   # with your 10-char Apple Developer Team ID. After that, `make
//   # ios-build` / Xcode UI both pick up the team automatically — the
//   # value flows from local.xcconfig through `configFiles:` in
//   # project.yml into the generated .xcodeproj.
//
// Other settings below (SUPABASE_URL, SENTRY_DSN_IOS, etc.) are optional —
// leave them empty for local-only mode (no live backend, no analytics).

// Apple Developer Team ID (10-char alphanumeric)
// Find via: security find-identity -v -p codesigning | grep "Developer"
// Or Apple Developer portal > Membership > Team ID
DEVELOPMENT_TEAM = YOUR_TEAM_ID_HERE

// Phase F1 — Sentry DSN for the iOS Sentry project. Get this from:
// Sentry > Settings > Projects > skeinly-ios > Client Keys (DSN).
// Leave empty to disable Sentry init (local-only / dev mode).
// CI injects via the SENTRY_DSN_IOS GitHub Secret per docs/{en,ja}/release-secrets.md §15.
//
// xcconfig // characters in values must be escaped — use a slash trick:
// SENTRY_DSN_IOS = https:/$()/<rest-of-dsn>  (NOTE the $() to break // sequence)
// See https://pewpewthespells.com/blog/xcconfig_guide.html for details.
SENTRY_DSN_IOS =

// Phase F2 — PostHog Project API Key + Host. Get the key from:
// PostHog > Settings > Project > Project API Key (phc_… prefix).
// Empty key disables PostHog init (privacy-safe local-only mode).
//
// POSTHOG_HOST: the `i.` subdomain is load-bearing — this is the *SDK
// ingestion* endpoint (event capture + feature flags), distinct from
// the dashboard URL you see in your browser:
//   - SDK ingestion (this value):  https:/$()/us.i.posthog.com  |  https:/$()/eu.i.posthog.com
//   - Dashboard / private API:     https:/$()/us.posthog.com    |  https:/$()/eu.posthog.com
// Pasting the dashboard URL here will silently fail to deliver events.
// Verified against PostHog docs (api / libraries/ios) as of 2026-05.
//
// xcconfig // escape: as with SUPABASE_URL above, write the value as
//   POSTHOG_HOST = https:/$()/us.i.posthog.com
// to break the literal `//` sequence that the xcconfig parser would
// otherwise treat as a line comment.
POSTHOG_API_KEY =
POSTHOG_HOST =

// Phase 39.1 — Supabase backend URL and Publishable key
// (`sb_publishable_…` form). Both URL and Publishable key are safe to
// expose in client binaries per Supabase docs (RLS enforced server-side).
// The legacy `anon` JWT key was deprecated 2025-11-01 — do not use it
// for new builds.
//
// xcconfig // escape applies to the URL value:
//   SUPABASE_URL = https:/$()/<project-ref>.supabase.co
SUPABASE_URL =
SUPABASE_PUBLISHABLE_KEY =

// Phase 41.3 (ADR-016 §6 §41.3) — RevenueCat Public iOS SDK Key.
// Get the key from RevenueCat Dashboard > API Keys > Public iOS SDK Key
// (starts with `appl_`). See vendor-setup.md A0d-2 + release-secrets §19.
// Empty key disables RevenueCatBootstrap.configure (paywall surfaces a
// "subscriptions unavailable" error rather than crashing on Purchases.sharedInstance).
REVENUECAT_API_KEY =
