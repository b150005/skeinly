# Fastfile — drives iOS Release/TestFlight CI pipeline.
#
# Lanes:
#   - beta       : Archive + sign + export IPA + upload to TestFlight (CI use)
#   - build_ipa  : Local IPA build with no upload (verification before push)
#
# Code-signing strategy: manual (per ADR-007 / Phase 19c).
#   - Distribution cert .p12 is passed via base64-encoded GitHub Secret,
#     decoded into a temporary CI keychain by `setup_ci` + `import_certificate`.
#   - **Provisioning profile is fetched from Apple Developer Portal at every
#     CI run via the App Store Connect API key + `sigh` action** (Phase 39 /
#     2026-05-10 refactor). The legacy `APPLE_PROVISIONING_PROFILE_BASE64`
#     secret is no longer read — capability changes (Push Notifications,
#     Associated Domains, etc.) propagate by re-Generating the profile in
#     Apple Developer Portal once; the next CI run picks up the new
#     profile automatically with no GitHub Secret update needed.
#   - App Store Connect API authentication via .p8 + key ID + issuer ID,
#     also from secrets. Reused for both `sigh` (profile fetch) and
#     `upload_to_testflight` (IPA upload).
#   - Local invocation: developer's own keychain + manually-installed profile.
#
# Required env vars (CI):
#   APPLE_DISTRIBUTION_CERT_BASE64       — base64 of Apple Distribution .p12
#   APPLE_DISTRIBUTION_CERT_PASSWORD     — password used when exporting .p12
#   APPLE_TEAM_ID                      — 10-char Team ID
#   APP_STORE_CONNECT_API_KEY_BASE64   — base64 of .p8 private key
#   APP_STORE_CONNECT_API_KEY_ID       — 10-char Key ID
#   APP_STORE_CONNECT_ISSUER_ID        — UUID Issuer ID
#   MARKETING_VERSION                  — e.g. "0.1.0" (from tag)
#   CURRENT_PROJECT_VERSION            — e.g. github.run_number
#
# Removed (no longer read; safe to delete from GitHub Secrets after the
# first successful CI run on the new pipeline):
#   APPLE_PROVISIONING_PROFILE_BASE64  — superseded by sigh + API key fetch

default_platform(:ios)

PRODUCT_BUNDLE_ID = "io.github.b150005.skeinly".freeze
PROVISIONING_PROFILE_NAME = "Skeinly App Store".freeze

platform :ios do
  before_all do
    setup_ci if ENV["CI"]
  end

  desc "Build IPA, sign with manual signing, and upload to TestFlight."
  lane :beta do
    if ENV["CI"]
      install_distribution_cert
      api_key = setup_app_store_connect_api_key
      profile_name = fetch_provisioning_profile(api_key)
    else
      profile_name = resolve_profile_name_from_local
      api_key = nil
    end

    build_app(
      project: "iosApp.xcodeproj",
      scheme: "iosApp",
      configuration: "Release",
      export_method: "app-store",
      export_options: {
        signingStyle: "manual",
        provisioningProfiles: {
          PRODUCT_BUNDLE_ID => profile_name,
        },
      },
      xcargs: build_xcargs,
      output_directory: output_dir,
      output_name: "iosApp.ipa",
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      skip_submission: true,
    )
  end

  desc "Build a Release IPA locally with no TestFlight upload (verification only)."
  lane :build_ipa do
    build_app(
      project: "iosApp.xcodeproj",
      scheme: "iosApp",
      configuration: "Release",
      export_method: "app-store",
      skip_codesigning: ENV["SKIP_CODESIGNING"] == "true",
      output_directory: "./build/ipa-output",
      output_name: "iosApp.ipa",
    )
  end
end

# ---------- helpers ----------

# Decode the Apple Distribution .p12 from APPLE_DISTRIBUTION_CERT_BASE64
# and import it into the temp keychain set up by `setup_ci`. The cert's
# private key is required for manual signing — sigh fetches the public
# profile, but the private key for signing the IPA must already be in
# the keychain when xcodebuild runs.
#
# Cert rotation cadence is once per year (Apple Distribution cert
# 1-year expiry). When that happens, regenerate the .p12 locally and
# update APPLE_DISTRIBUTION_CERT_BASE64. Profile changes (Push, App
# Links, Sign In with Apple, etc.) do NOT require touching this secret
# — only `sigh` re-fetches the matching profile on the next CI run.
def install_distribution_cert
  require "base64"
  runner_temp = ENV["RUNNER_TEMP"] || Dir.mktmpdir

  cert_path = File.join(runner_temp, "distribution.p12")
  cert_b64 = ENV["APPLE_DISTRIBUTION_CERT_BASE64"]
  UI.user_error!("APPLE_DISTRIBUTION_CERT_BASE64 is required in CI") if cert_b64.to_s.empty?
  File.binwrite(cert_path, Base64.decode64(cert_b64))

  import_certificate(
    certificate_path: cert_path,
    certificate_password: ENV["APPLE_DISTRIBUTION_CERT_PASSWORD"],
    keychain_name: ENV["MATCH_KEYCHAIN_NAME"] || "fastlane_tmp_keychain",
    keychain_password: ENV["MATCH_KEYCHAIN_PASSWORD"] || "",
  )
end

# Build an `app_store_connect_api_key` token from the .p8 + key ID +
# issuer ID secrets. The returned Hash is reusable for both `sigh`
# (provisioning profile fetch) and `upload_to_testflight` (IPA upload),
# so we set it up once per lane invocation.
#
# `is_key_content_base64: false` because we Base64.decode64 the secret
# before passing — fastlane's own base64-decode path inside the action
# is also valid but doing it here keeps the call site uniform with the
# .p12 handling above.
def setup_app_store_connect_api_key
  require "base64"
  key_id = ENV["APP_STORE_CONNECT_API_KEY_ID"]
  issuer_id = ENV["APP_STORE_CONNECT_ISSUER_ID"]
  key_b64 = ENV["APP_STORE_CONNECT_API_KEY_BASE64"]
  UI.user_error!("APP_STORE_CONNECT_API_KEY_ID is required") if key_id.to_s.empty?
  UI.user_error!("APP_STORE_CONNECT_ISSUER_ID is required") if issuer_id.to_s.empty?
  UI.user_error!("APP_STORE_CONNECT_API_KEY_BASE64 is required") if key_b64.to_s.empty?

  app_store_connect_api_key(
    key_id: key_id,
    issuer_id: issuer_id,
    key_content: Base64.decode64(key_b64),
    is_key_content_base64: false,
    duration: 1200, # max 1200 (20 min). Both sigh + pilot calls fit well within.
  )
end

# Fetch the App Store distribution provisioning profile from Apple
# Developer Portal via the App Store Connect API key. Returns the
# profile's Name field (xcodebuild needs the Name, not the file path,
# in `provisioningProfiles` for manual signing export options).
#
# **`force: false` + `provisioning_name: "Skeinly App Store"` strategy:**
# - Each CI run fetches the existing profile by name. No portal mutation.
# - Capability changes (Push Notifications added, Associated Domains
#   added, etc.) are absorbed by re-Generating the profile manually in
#   Apple Developer Portal once (single click in the Portal UI).
#   `sigh` reads the regenerated profile by name on the next CI run —
#   GitHub Secrets do NOT need updating.
# - Profile expiry (1-year on Apple Distribution profiles) similarly
#   resolves with a Portal re-Generate; CI auto-pickup follows.
# - We deliberately avoid `force: true` because that path creates a NEW
#   profile every CI run — Apple Developer Portal accumulates them and
#   eventually hits the per-app provisioning profile soft cap. Reading
#   an existing-name profile keeps the Portal tidy.
#
# `output_path: runner_temp` writes the .mobileprovision so
# `install_provisioning_profile` (called inside sigh) can place it
# into the active keychain location for xcodebuild to find. The file
# is also kept for diagnostic logs in case of a failure.
def fetch_provisioning_profile(api_key)
  runner_temp = ENV["RUNNER_TEMP"] || Dir.mktmpdir

  # `adhoc:` and `development:` are mutually exclusive in sigh — passing
  # both (even when both `false`) trips its option-conflict validator
  # ("Error resolving conflict between options: 'adhoc' and 'development'").
  # The App Store distribution profile is sigh's default when NEITHER
  # flag is passed, so we omit both. Only pass one of these explicitly
  # if/when we add an `:adhoc` lane (e.g. for QA distribution outside
  # TestFlight).
  #
  # `force: true` — regenerate the profile from Apple Developer Portal
  # on every CI run. This is the only setting that guarantees the
  # downloaded profile carries the current App ID capability set
  # (Associated Domains, Push Notifications, Sign In with Apple,
  # In-App Purchase). With `force: false`, sigh would download whatever
  # existing profile matches the name — including a stale one that was
  # created before the most recent capability was added to the App ID.
  # The 2026-05-11 Path Y first attempt failed exactly that way
  # (existing profile UUID `e04fc65a-0e67-...` predated the
  # Associated Domains add for W3).
  #
  # Trade-off: Apple Developer Portal accumulates archived profiles
  # (one per CI run) under the App ID. Apple's per-app per-type
  # active-profile cap (~120 for distribution) won't bite for ~24 days
  # at 5 runs/day, which is past alpha. Post-alpha cleanup options:
  # (a) periodically delete archived profiles via App Store Connect
  # API, or (b) switch to `force: false` once the capability set
  # stabilizes (the user's manual re-Generate on capability change
  # then suffices).
  sigh(
    app_identifier: PRODUCT_BUNDLE_ID,
    api_key: api_key,
    force: true,
    provisioning_name: PROVISIONING_PROFILE_NAME,
    ignore_profiles_with_different_name: true,
    output_path: runner_temp,
    filename: "distribution.mobileprovision",
  )

  profile_name = lane_context[SharedValues::SIGH_NAME]
  UI.user_error!("sigh did not return a profile name") if profile_name.to_s.empty?
  profile_name
end

# Local-dev path: read profile name from the user's manually-installed
# profile under either the legacy or Xcode 16+ install dir. Unchanged
# from the pre-Path-Y shape — only the CI path is automated.
def resolve_profile_name_from_local
  legacy_dir = File.expand_path("~/Library/MobileDevice/Provisioning Profiles")
  xcode16_dir = File.expand_path("~/Library/Developer/Xcode/UserData/Provisioning Profiles")
  candidates = Dir.glob("#{xcode16_dir}/*.mobileprovision") +
               Dir.glob("#{legacy_dir}/*.mobileprovision")
  if candidates.empty?
    UI.user_error!(
      "No provisioning profile found in #{xcode16_dir} or #{legacy_dir}",
    )
  end
  profile_path = candidates.first

  decoded_xml = `security cms -D -i "#{profile_path}" 2>/dev/null`
  match = decoded_xml.match(%r{<key>Name</key>\s*<string>([^<]+)</string>})
  UI.user_error!("Provisioning profile is missing the 'Name' field") if match.nil?
  match[1]
end

# Build the xcargs string passed to xcodebuild via build_app. Versioning
# (MARKETING_VERSION + CURRENT_PROJECT_VERSION) is sourced from CI env so
# the tag/run-number drives the iOS bundle version. CODE_SIGN_STYLE +
# CODE_SIGN_IDENTITY pinned to manual + Apple Distribution. Vendor SDK
# configuration (Supabase / Sentry / PostHog) is also passed through —
# the values land as build settings, which Info.plist resolves via
# `$(VAR)` placeholders declared in project.yml. This is the single
# injection point in the CI/Release path; the local.xcconfig file used
# locally provides the same settings via a different surface.
def build_xcargs
  args = []
  args << "MARKETING_VERSION=#{ENV['MARKETING_VERSION']}" unless ENV["MARKETING_VERSION"].to_s.empty?
  args << "CURRENT_PROJECT_VERSION=#{ENV['CURRENT_PROJECT_VERSION']}" unless ENV["CURRENT_PROJECT_VERSION"].to_s.empty?
  args << "DEVELOPMENT_TEAM=#{ENV['APPLE_TEAM_ID']}" unless ENV["APPLE_TEAM_ID"].to_s.empty?
  args << "SUPABASE_URL=#{shell_escape(ENV['SUPABASE_URL'])}" unless ENV["SUPABASE_URL"].to_s.empty?
  args << "SUPABASE_PUBLISHABLE_KEY=#{shell_escape(ENV['SUPABASE_PUBLISHABLE_KEY'])}" unless ENV["SUPABASE_PUBLISHABLE_KEY"].to_s.empty?
  args << "SENTRY_DSN_IOS=#{shell_escape(ENV['SENTRY_DSN_IOS'])}" unless ENV["SENTRY_DSN_IOS"].to_s.empty?
  args << "POSTHOG_API_KEY=#{shell_escape(ENV['POSTHOG_PROJECT_API_KEY'])}" unless ENV["POSTHOG_PROJECT_API_KEY"].to_s.empty?
  args << "POSTHOG_HOST=#{shell_escape(ENV['POSTHOG_HOST'])}" unless ENV["POSTHOG_HOST"].to_s.empty?
  args << "CODE_SIGN_STYLE=Manual"
  args << 'CODE_SIGN_IDENTITY="Apple Distribution"'
  args.join(" ")
end

# Quote a value for safe inclusion in the xcargs string. xcodebuild
# splits xcargs on whitespace, so any value containing spaces, quotes,
# or shell metacharacters must be wrapped. URLs with `//` are fine here
# — the xcconfig comment-marker pitfall does not apply because xcargs
# values are injected directly as build settings, not via xcconfig.
def shell_escape(value)
  return "" if value.nil? || value.empty?
  "'#{value.gsub("'", "'\\\\''")}'"
end

# Where build_app writes the .ipa. On CI, prefer $RUNNER_TEMP so cleanup
# is automatic when the runner VM is recycled. Locally, fall back to the
# project's build dir.
def output_dir
  base = ENV["RUNNER_TEMP"] || "./build"
  File.join(base, "ipa-output")
end
