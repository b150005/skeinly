<?xml version="1.0" encoding="utf-8"?>
<!--
  androidApp-only resources — strings the Android platform itself
  (AndroidManifest, system overlays) reads via @string/*. User-facing
  copy lives in shared/src/commonMain/composeResources (consumed via
  Res.string/Res.plurals from Compose) and iosApp/Localizable.xcstrings;
  see ./gradlew verifyI18nKeys for the parity check across those two
  source sets.
-->
<resources>
    <string name="app_name">Skeinly</string>
    <!-- Phase 24.5 (ADR-017 §3.8) — collaboration notification channel.
         User-visible name + description shown in the OS Settings →
         Notifications → Skeinly screen, so the user can mute
         collaboration pushes independently of any future channel.
         English-only is acceptable here because this resource is read
         by the Android system (NotificationChannel API) which always
         resolves to the device's default Skeinly resource set;
         per-locale variants live under values-ja/strings.xml. -->
    <string name="notification_channel_collaboration">Collaboration</string>
    <string name="notification_channel_collaboration_description">
        Pull-request opens, comments, merges, and closes.
    </string>
</resources>
