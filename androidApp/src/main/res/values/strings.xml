    <!-- Shared with me screen (list of shares received by the current user).
         Android renders a single "From X | Shared on Y | Permission | Status"
         Text line with pipe separators; iOS renders bullet-separated Text
         fragments in an HStack — platform-idiom divergence is acceptable. Both
         resolve a null sharer to `label_someone` (reused from 33.1.7 ActivityFeed)
         and a null patternTitle to `label_unknown_pattern`. `label_from_user` is
         parametric so JA can use natural grammar (%1$sから) rather than EN-spaced
         "From %1$s". `label_share_status_{pending,declined}` is a distinct domain
         from `label_status_*` (project status filter) — share status and project
         status are different taxonomies. ACCEPTED status has no label because
         an accepted share is simply a visible list entry with no qualifier. -->
    <string name="title_shared_with_me">Shared With Me</string>
