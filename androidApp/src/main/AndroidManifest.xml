<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- Phase 24.2d (ADR-017 §3.6) — runtime POST_NOTIFICATIONS gate
         enforced from Android 13 (API 33). Below 33 the install-time grant
         is implicit; the declaration here is required regardless because
         the runtime request only fires once the manifest declares the
         permission. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".SkeinlyApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:supportsRtl="true"
        android:theme="@style/Theme.Skeinly">

        <!-- Disable Sentry auto-init via SentryInitProvider. The auto-init path
             requires a DSN at startup and crashes when DSN is empty
             (IllegalArgumentException: "DSN is required."). Local-only builds
             (CI E2E, devs without secrets) ship with empty SENTRY_DSN_ANDROID.
             SkeinlyApplication.onCreate() handles init manually with a
             non-empty DSN guard, so this just defers Sentry to that path. -->
        <meta-data
            android:name="io.sentry.auto-init"
            android:value="false" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/Theme.Skeinly">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!--
                Phase 39 (W3 / 2026-05-11) — Android App Links.

                `autoVerify="true"` triggers Play's domain verification:
                Android fetches `https://b150005.github.io/.well-known/assetlinks.json`
                during app install, validates the SHA256 fingerprint matches
                this APK's signing cert, and only then routes matching URLs
                directly to the app (skipping the "Open with…" disambiguation).
                If verification fails, links fall back to the browser.

                URL family handled (per W3 deep-link audit, 2026-05-10):
                  /skeinly/patterns/shared/*    — share token deep link
                  /skeinly/patterns/*           — public pattern detail
                  /skeinly/pull-requests/*      — pull request detail

                pathPrefix is broad here (`/skeinly/`) — the actual route
                discrimination happens in MainActivity.handleDeepLinkUri()
                via `parseExternalRoute(...)` (commonMain). Anything that
                doesn't match a known route is dropped silently (the user
                lands on the launcher destination, no crash).

                The legacy `skeinly://share/<token>` custom scheme intent
                filter was DELETED in this slice (no Tech Debt fallback)
                because pre-v1 breaking changes are accepted (closed alpha
                has no installed clients depending on the old URL shape).
            -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="https"
                    android:host="b150005.github.io"
                    android:pathPrefix="/skeinly/" />
            </intent-filter>
        </activity>

        <!-- Phase 24.5 (ADR-017 §3.8) — FCM message handler. Receives
             foreground deliveries (background+killed are auto-displayed
             by FCM with `data` map flowing into MainActivity intent
             extras at tap time, so this service does NOT see those).
             android:exported="false" because only the FCM library
             dispatches to us via the standard intent action — no
             external app should be able to invoke. -->
        <service
            android:name=".notifications.SkeinlyMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>
    </application>

</manifest>
